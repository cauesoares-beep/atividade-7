    /**
     * Testa o cadastro e a pesquisa de um aluno.
     */
    @Test
    public void testeCadastrarAluno() {

        Aluno aluno = new Aluno(
                "2024001",
                "João Silva",
                "Computação",
                20);

        sistema.cadastrarAluno(aluno);

        Aluno resultado = sistema.pesquisarAluno("2024001");

        assertNotNull(resultado);
        assertEquals("João Silva", resultado.getNome());
        assertEquals("Computação", resultado.getCurso());
        assertEquals(20, resultado.getIdade());

    }

